# =============================================================================
# BuonDesizn B2B Marketplace — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or any file with real credentials.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase [REQUIRED]
# Get from: Supabase Dashboard → Project Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=REPLACE_ME
SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME_NEVER_EXPOSE_CLIENT_SIDE

# -----------------------------------------------------------------------------
# App URL [REQUIRED]
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# PhonePe PG [REQUIRED for Phase 3 — subscriptions & ads]
# Get from: PhonePe business dashboard
# -----------------------------------------------------------------------------
PHONEPE_MERCHANT_ID=REPLACE_ME
PHONEPE_MERCHANT_KEY=REPLACE_ME
PHONEPE_SALT_INDEX=1
PHONEPE_ENVIRONMENT=UAT
PHONEPE_BASE_URL=https://api-preprod.phonepe.com/apis/pg-sandbox

# -----------------------------------------------------------------------------
# Sightengine [REQUIRED for Phase 3 — content moderation]
# Get from: sightengine.com
# -----------------------------------------------------------------------------
SIGHTENGINE_API_USER=REPLACE_ME
SIGHTENGINE_API_SECRET=REPLACE_ME

# -----------------------------------------------------------------------------
# Upstash QStash [REQUIRED for Phase 3 — async jobs]
# Get from: upstash.com
# -----------------------------------------------------------------------------
QSTASH_TOKEN=REPLACE_ME
QSTASH_CURRENT_SIGNING_KEY=REPLACE_ME
QSTASH_NEXT_SIGNING_KEY=REPLACE_ME

# -----------------------------------------------------------------------------
# Sentry [OPTIONAL — error tracking]
# Get from: sentry.io
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=REPLACE_ME
SENTRY_AUTH_TOKEN=REPLACE_ME
SENTRY_ORG=REPLACE_ME
SENTRY_PROJECT=buondesizn-b2b

# -----------------------------------------------------------------------------
# Axiom [OPTIONAL — logging & analytics]
# Get from: axiom.co
# -----------------------------------------------------------------------------
AXIOM_TOKEN=REPLACE_ME
AXIOM_DATASET=buondesizn-prod
